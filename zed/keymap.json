[
  {
    "context": "Editor",
    "bindings": {
      "alt-x": "command_palette::Toggle",
      "ctrl-'": "editor::GoToDefinition",
      "alt-'": "editor::GoToImplementation",
      "ctrl-alt-;": "editor::GoToImplementation",
      "ctrl-g": "editor::Cancel",
      "alt-g": "go_to_line::Toggle",
      "ctrl-s": "buffer_search::Deploy",
      "ctrl-alt-5": "buffer_search::DeployReplace",
      "ctrl-shift-f": "pane::DeploySearch",
      "ctrl-alt-/": "editor::Redo",
      "alt-r": "editor::Rename",
      "ctrl-alt-i": "editor::AutoIndent",
      "ctrl-m": "editor::Newline",
      "ctrl-o": [
        "action::Sequence",
        [
          "editor::NewlineBelow",
          "editor::MoveUp"
        ]
      ],
      "ctrl-a": [
        "action::Sequence",
        [
          "editor::MoveToBeginningOfLine",
          "editor::MoveRight"
        ]
      ],
      "ctrl-u": "editor::DeleteToBeginningOfLine",
      "alt-w": [
        "action::Sequence",
        [
          "editor::Copy",
          "editor::Cancel"
        ]
      ],
      "ctrl-y": "editor::Paste",
      "alt-y": "editor::Paste",
      "ctrl-alt-w": "editor::SelectLargerSyntaxNode",
      "cmd-[": "pane::ActivatePreviousItem",
      "cmd-]": "pane::ActivateNextItem",
      "ctrl-enter": null,
      "cmd-d": "editor::ToggleBreakpoint",
      "ctrl-[": "editor::MoveToEnclosingBracket",
      "ctrl-]": "editor::MoveToEnclosingBracket",
      "ctrl-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-backslash": "workspace::ToggleLeftDock",
      "alt-t": "terminal_panel::Toggle",
      "ctrl-t": "terminal_panel::Toggle",
      "ctrl-alt-a": "agent::ToggleFocus",
      "cmd-1": "project_panel::Toggle",
      "cmd-2": "git_panel::Toggle",
      "shift-f9": "debugger::Start",
      "cmd-r": "task::Rerun",
      "ctrl-r": "task::Rerun",
      "shift-ctrl-n": "workspace::NewFile",
      "cmd-n": "agent::NewThread",
      "shift-ctrl-c": "git::Commit"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-1": "project_panel::Toggle",
      "cmd-2": "git_panel::Toggle"
    }
  },
  {
    "context": "DiffEditor",
    "bindings": {
      "ctrl-9": "editor::GoToHunk",
      "ctrl-0": "editor::GoToHunk",
      "ctrl-8": "git::ToggleStaged"
    }
  },
  {
    "context": "Editor && selection",
    "bindings": {
      "ctrl-a": [
        "action::Sequence",
        [
          "editor::MoveToBeginningOfLine",
          "editor::MoveRight",
          "editor::SelectToEndOfLine"
        ]
      ]
    }
  },
  {
    "context": "Editor && multibuffer",
    "bindings": {
      "ctrl-enter": "editor::OpenExcerpts"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-]": "pane::ActivateNextItem",
      "cmd-[": "pane::ActivatePreviousItem",
      "ctrl-x ctrl-n": "pane::ActivateNextItem",
      "ctrl-x ctrl-p": "pane::ActivatePreviousItem",
      "ctrl-f4": "pane::CloseActiveItem",
      "ctrl-x k": "pane::CloseActiveItem",
      "ctrl-x ctrl-c": "pane::CloseActiveItem"
    }
  }
]
